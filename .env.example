# ===========================================
# Wahb CMS Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# Production URL: https://cms.salehspace.dev

# Environment (development, production)
ENV=development

# Public origin used to build absolute syndication (RSS/Atom/JSON) feed links.
# Production: https://cms.salehspace.dev — falls back to the request host if unset.
PUBLIC_BASE_URL=http://localhost:8080

# ===========================================
# DATABASE CONNECTION (Required)
# ===========================================
# PostgreSQL connection URL - This is the ONLY supported database configuration method
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable

# For local development (recommended):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wahb_db?sslmode=disable

# For Docker Compose with local db service:
# DATABASE_URL=postgres://postgres:your_secure_password_here@db:5432/wahb_db?sslmode=disable

# For production with Supabase - USE CONNECTION POOLER (port 6543, not 5432):
# Get this from: Supabase Dashboard → Connect → Transaction pooler
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# ===========================================
# OPTIONAL SERVICES
# ===========================================
# Redis Configuration (for caching - future use)
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=8080

# ===========================================
# ADMIN AUTH (Optional for local/dev)
# ===========================================
# Used to seed a default admin user in development
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRATION_HOURS=24
JWT_ISSUER=cms-service
JWT_AUDIENCE=platform-console
JWT_ALLOWED_ISSUERS=iam-authorization-service
# Required in production: the IAM audience intended for CMS human routes.
JWT_ALLOWED_AUDIENCES=platform-console
JWT_REQUIRE_TENANT_ID=false
DEFAULT_TENANT_ID=default
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_ROLE=admin

# ===========================================
# INTERNAL SERVICE AUTH — capability-exact machine credentials
# ===========================================
# One credential per caller. Supply the matching value only to that service.
CMS_AGGREGATION_SERVICE_TOKEN=replace_with_aggregation_cms_token
CMS_ENRICHMENT_SERVICE_TOKEN=replace_with_enrichment_cms_token
CMS_MEDIA_SERVICE_TOKEN=replace_with_media_cms_token
# Optional next credentials permit deliberate overlap during rotation.
# CMS_AGGREGATION_SERVICE_TOKEN_NEXT=
# CMS_ENRICHMENT_SERVICE_TOKEN_NEXT=
# CMS_MEDIA_SERVICE_TOKEN_NEXT=
# Deprecated bridge for an existing shared deployment only. In production set
# its explicit RFC3339 removal time before rollout, then remove both values.
# CMS_SERVICE_TOKEN=replace_with_legacy_shared_token
# CMS_LEGACY_SERVICE_TOKEN_UNTIL=2026-10-15T00:00:00Z

# ===========================================
# INTERNAL SERVICE PROBES + CALLS
# ===========================================
IAM_BASE_URL=http://localhost:4003
AGGREGATION_BASE_URL=http://localhost:5002
ENRICHMENT_BASE_URL=http://localhost:5050
MEDIA_BASE_URL=http://localhost:5051
PLATFORM_BASE_URL=http://localhost:3000

# Tokens must match each service's SERVICE_AUTH_TOKEN where required.
# Aggregation is used by Pipeline/News/Enrichment autopilots and System Health queue probes.
# CMS calls Aggregation's /internal routes with this token (not a human JWT).
AGGREGATION_CMS_SERVICE_TOKEN=replace_with_cms_to_aggregation_token
# The scheduled Media Circulation Autopilot is accepted only by Aggregation's
# atomization sweep endpoint; it cannot access ordinary admin routes.
AGGREGATION_AUTOMATION_TOKEN=replace_with_aggregation_automation_token
# ENRICHMENT_SERVICE_TOKEN=replace_with_enrichment_token
# MEDIA_SERVICE_TOKEN=replace_with_media_token

# ===========================================
# MIGRATIONS (Optional)
# ===========================================
# Set true only when ./start.sh should apply pending timestamped SQL migrations.
AUTO_SQL_MIGRATE=false
